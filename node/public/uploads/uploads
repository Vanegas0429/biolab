import express from 'express'
import { getAllEquipos, getEquipo, createEquipo, updateEquipo, deleteEquipo } from '../controllers/EquipoController.js'
import multer from 'multer'
import path from 'path'
import authMiddleware from '../../middleware/authMiddleware.js' // Importado según tu estructura

const router = express.Router()

// Configuración de almacenamiento para multer
const almacenamiento = multer.diskStorage({
    // Definir la carpeta donde quedarán los archivos
    destination: (req, file, cb) => {
        // cb es una función que se utiliza para indicar el destino del archivo
        cb(null, 'public/uploads/')
    },
    // Renombrar el archivo con la marca de tiempo actual
    filename: (req, file, cb) => {
        cb(null, Date.now() + path.extname(file.originalname))
    }
})

const upload = multer({ storage: almacenamiento })

// --- Rutas para Equipos ---

// Obtener todos los equipos (Protegido con middleware)
router.get('/', authMiddleware, getAllEquipos)

// Obtener un equipo por ID
router.get('/:id', authMiddleware, getEquipo)

// Crear un equipo con subida de imagen
router.post('/', authMiddleware, upload.single('foto'), createEquipo)

// Actualizar un equipo (también permite actualizar la foto)
router.put('/:id', authMiddleware, upload.single('foto'), updateEquipo)

// Eliminar un equipo
router.delete('/:id', authMiddleware, deleteEquipo)

export default router